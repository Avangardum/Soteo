; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=4

[application]

config/name="Soteo"
run/main_scene="res://Scenes/LogIn.tscn"
config/icon="res://icon.png"

[autoload]

AsyncExceptionCollector="*res://Scripts/Nodes/Autoloads/AsyncExceptionCollector.cs"
CharacterSpawner="*res://Scripts/Nodes/Autoloads/CharacterSpawner.cs"
ClientShardServerCommunicator="*res://Scripts/Nodes/Autoloads/ClientShardServerCommunicator.cs"
MasterServerCommunicator="*res://Scripts/Nodes/Autoloads/MasterServerCommunicator.cs"
ServiceProvider="*res://Scripts/Nodes/Autoloads/ServiceProvider.cs"

[gdnative]

singletons=[ "res://webrtc/webrtc.tres" ]

[gui]

common/drop_mouse_on_gui_input_disabled=true

[mono]

project/assembly_name="Soteo"

[physics]

common/enable_pause_aware_picking=true

[rendering]

quality/driver/driver_name="GLES2"
vram_compression/import_etc=true
vram_compression/import_etc2=false
environment/default_environment="res://default_env.tres"
