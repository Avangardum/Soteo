[layer_names]

2d_physics/layer_1="Default"
2d_physics/layer_9="ClickArea"

[locale]

translations=PoolStringArray( "res://Localization/English.en.translation", "res://Localization/Russian.ru.translation" )

[mono]

project/assembly_name="Soteo"

[network]

ssl/certificates="res://devcert.crt"
limits/webrtc/max_channel_in_buffer_kb=100000

[physics]

common/physics_fps=20
common/enable_pause_aware_picking=true

[rendering]

quality/driver/driver_name="GLES2"
vram_compression/import_etc=true
vram_compression/import_etc2=false
environment/default_clear_color=Color( 0.0313726, 0.0431373, 0.0784314, 1 )
environment/default_environment="res://default_env.tres"
